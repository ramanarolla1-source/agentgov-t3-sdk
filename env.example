# Terminal 3 Configuration
# Obtain your API key from the Terminal 3 Developer Dashboard
T3_API_KEY=your_sandbox_api_key_here

# Execution Environment
# Set to 'sandbox' for testing or 'production' for live deployments
T3_MODE=sandbox

# Optional: Governance Policy Thresholds
# Maximum transfer amount allowed by policy engine
MAX_TRANSFER_THRESHOLD=5000
